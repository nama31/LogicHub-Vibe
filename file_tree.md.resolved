│   ├── next.config.ts              # Next.js-конфиг
│   ├── tailwind.config.ts          # Tailwind-конфиг
│   ├── postcss.config.js           # PostCSS-конфиг
│   ├── .env.local.example          # NEXT_PUBLIC_API_URL и др.
